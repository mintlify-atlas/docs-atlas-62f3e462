  "keyFeatures": [
    "Multi-database support (SQLite, PostgreSQL, MySQL, SQL Server)",
    "Connection management with save, test, and organize capabilities",
    "Schema exploration to browse tables, columns, and indexes",
    "Data browsing with beautiful terminal UI",
    "Interactive SQL query execution mode",
    "Data export to CSV and JSON formats",
